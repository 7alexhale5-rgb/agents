# Honcho — copy to .env (gitignored) and fill in values
# Phase 1.5 (laptop self-host)

# Database
HONCHO_DB_PASSWORD=change-me-to-a-long-random-string

# Auth (JWT secret for tenant isolation)
HONCHO_JWT_SECRET=change-me-to-another-long-random-string

# Model providers (Honcho's three reasoning agents call out to one or more of these)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Observability
HONCHO_SENTRY_DSN=

# To generate strong secrets:
#   openssl rand -hex 32
