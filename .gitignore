# Secrets — never in git
**/.env
**/.env.local
**/*.secret

# Runtime / generated — versioned tree never includes these
**/scratch/
**/memory/state.db
**/memory/trajectories/
**/memory/*.sqlite*
**/workspace/

# Hermes runtime drop-ins (in case anyone runs hermes from inside a profile dir)
**/.hermes/

# Kill-switches are local; only the *.template form is tracked
**/PAUSED
!**/PAUSED.template

# Tenants are per-client, never committed
tenants/*/
!tenants/_provisioning/
!tenants/README.md

# Honcho local data
honcho/workspaces/*/
!honcho/workspaces/README.md

# Python / Node / OS
**/__pycache__/
**/.venv/
**/.coverage
.coverage.*
**/htmlcov/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/node_modules/
# Lighthouse audit placeholder static site (from npm run build)
/dist/
**/.DS_Store
*.log
**/*.egg-info/

# Playwright (repo-root audit smoke)
/test-results/
/playwright-report/

# Promptfoo nightly run outputs — regenerated, not source-of-truth
marketplace/manifests/*/eval-suite/reports/

# Shadow workspaces created by scripts/clone-profile-baseline.sh — generated,
# regenerated on demand, not source-of-truth.
hermes/profiles/*-baseline/

# Local Claude Code worktrees (per-session, never committed)
.claude/worktrees/

# Raw research artifact dumps (conclusions live in memory-vault decisions/)
.research/
