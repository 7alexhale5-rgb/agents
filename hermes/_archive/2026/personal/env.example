# Personal profile env — copy to .env (gitignored) and fill in
# Hermes runtime reads from ~/.hermes/profiles/personal/.env after `sync-profile.sh push personal`

# === Telegram (paired via @BotFather, NOT gravity-claw's existing token) ===
TELEGRAM_BOT_TOKEN_PERSONAL=

# === Model providers (BYOK; at least one required) ===
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=

# === Voice loop ===
GROQ_API_KEY=
GOOGLE_TTS_API_KEY=

# === Memory layer (Phase 1.5+) ===
HONCHO_URL=http://localhost:8765
HONCHO_JWT_TOKEN_PERSONAL=

# === Observability ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://langfuse.prettyflyforai.com

# === Spend cap ===
SPEND_CAP_USD_PER_DAY=5
